rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isGroupMember(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && isGroupMember(groupId);
      allow create: if isSignedIn();
      allow update, delete: if false;

      match /members/{memberId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow create: if isSignedIn();
        allow update: if isSignedIn() && request.auth.uid == memberId;
      }

      match /events/{eventId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow write: if false;
      }

      match /requests/{requestId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow update: if isSignedIn() && request.auth.uid == resource.data.assigneeUid;
        allow create, delete: if false;
      }

      match /counters/{counterId} {
        allow read: if isSignedIn() && isGroupMember(groupId);
        allow write: if false;
      }
    }
  }
}
